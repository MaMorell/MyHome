@using MudBlazor
@using MyHome.Core.Models.EnergySupplier
@attribute [StreamRendering(true)]
@attribute [OutputCache(Duration = 5)]

<MudCard Elevation="3">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h5" Color="Color.Primary">
                <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Class="mr-2" />
                Prisjusteringar
            </MudText>
        </CardHeaderContent>
    </MudCardHeader>

    <MudCardContent>
        @if (EnergyConsumptions is null)
        {
            <MudPaper Class="pa-8 d-flex align-center justify-center" Elevation="0">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            </MudPaper>
        }
        else
        {
            <MudPaper Elevation="0" Class="pa-4">
                <MudChart ChartType="ChartType.Timeseries"
                          ChartSeries="@_series"
                          @bind-SelectedIndex="_index"
                          MatchBoundsToSize="true"
                          CanHideSeries="true"
                          Width="100%"
                          Height="350px"
                          ChartOptions="_options" />
            </MudPaper>
        }
    </MudCardContent>
</MudCard>


